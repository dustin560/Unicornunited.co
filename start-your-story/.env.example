# ─── Start your Story — environment variables ───
# Copy this file to .env for local dev. In production these are set in Railway.

# Claude API (required — powers the AI game master)
ANTHROPIC_API_KEY=
MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=1024

# Resend (required — sends result emails)
RESEND_API_KEY=
NOTIFY_EMAIL=dustin@warpspeed.agency

# Notion (optional — persists completions to the Game Completions DBs)
# Create an integration at https://www.notion.so/profile/integrations,
# then share both databases with that integration.
NOTION_API_KEY=
NOTION_GAME_COMPLETIONS_DB_ID=6811019b02724c0eb1bad00660e3e6e7
# Personal mode (Unicorn for Leaders) — separate DB so personal completions
# can be triaged by the for-leaders concierge agent independently of business leads.
NOTION_PERSONAL_DB_ID=1bd22dbfe0bd4f6a9cde9c4b945934f6

# Server
PORT=3000
